# ─── Secrets (NEVER commit) ─────────────────────────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.*.local
# Apps/* .env.local files are auto-generated from the root by scripts/sync-env.mjs
apps/*/.env.local
apps/*/.env.*.local

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build outputs ──────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ─── Test & coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ─── Supabase local ─────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/.env

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── IDE & editor ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.qodo/
*.swp
*.swo
*~

# ─── Claude Code — commit shared config & skills, ignore local/session state ─
.claude/settings.local.json
.claude/projects/
.claude/sessions/
.claude/logs/

# ─── OS artifacts ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Misc ───────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.pem
