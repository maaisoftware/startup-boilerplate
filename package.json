{
  "name": "startup-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade, AI-ready monorepo template for rapidly bootstrapping new client projects with consistent architecture, security, and tooling.",
  "license": "MIT",
  "author": "Marlon Alejandro Espinosa Castañeiras",
  "homepage": "https://github.com/maaisoftware/startup-boilerplate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maaisoftware/startup-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/maaisoftware/startup-boilerplate/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "test:contract": "turbo run test:contract",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky",
    "postinstall": "node scripts/sync-env.mjs",
    "sync:env": "node scripts/sync-env.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/db/src/generated/supabase.ts",
    "db:migrate": "supabase migration up",
    "db:seed": "tsx packages/db/scripts/seed.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@startup-boilerplate/config": "workspace:*",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm exec prettier --write",
      "pnpm exec eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml,css}": [
      "pnpm exec prettier --write"
    ]
  }
}
