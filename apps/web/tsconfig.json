{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@startup-boilerplate/config/tsconfig/next.json",
  "compilerOptions": {
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", ".turbo", "out", "build", "dist", "coverage", "test-results", "playwright-report"]
}
