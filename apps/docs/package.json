{
  "name": "@startup-boilerplate/docs",
  "version": "0.1.0",
  "private": true,
  "description": "Docusaurus-powered external documentation site for the startup boilerplate.",
  "license": "MIT",
  "scripts": {
    "build": "docusaurus build",
    "dev": "docusaurus start --port 3100 --host 0.0.0.0",
    "start": "docusaurus serve --port 3100 --host 0.0.0.0",
    "clear": "docusaurus clear",
    "clean": "rm -rf build .docusaurus node_modules/.cache",
    "lint": "echo '(no lint configured for docs app)' && exit 0",
    "typecheck": "tsc --noEmit",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
