# ============================================================================
# Startup Boilerplate — Environment Variables
# ============================================================================
#
# Copy this file to `.env.local` and fill in the values you have.
# Every variable marked [REQUIRED] must be set for the app to boot.
# Variables marked [LOCAL-AUTO] are generated automatically by `supabase start`.
# Variables marked [OPTIONAL] can be left blank — the matching feature stays off.
#
# Boot-time validation: Zod schema in `packages/config/src/env.ts` refuses to
# start the app if any [REQUIRED] variable is missing or malformed.
#
# Security: Only variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser. Everything else is server-only. Do NOT commit this file when filled.
# ============================================================================


# ─── Core app ───────────────────────────────────────────────────────────────
NODE_ENV=development                                     # [REQUIRED] development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3000                # [REQUIRED] Public URL of the web app
NEXT_PUBLIC_APP_NAME=Startup Boilerplate                 # [REQUIRED] Displayed in page titles, OG tags
AUTH_SECRET=                                             # [REQUIRED] 32+ char random string. Generate: openssl rand -base64 32
CSRF_SECRET=                                             # [REQUIRED] 32+ char random string. Generate: openssl rand -base64 32


# ─── Supabase (local via `supabase start`) ──────────────────────────────────
# Run `supabase start` once; it prints these. Paste them here.
# Ports are shifted +100 from Supabase defaults so this project's Supabase
# stack coexists with other local Supabase projects on the same machine.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421          # [LOCAL-AUTO]
NEXT_PUBLIC_SUPABASE_ANON_KEY=                           # [LOCAL-AUTO] from `supabase start` output
SUPABASE_SERVICE_ROLE_KEY=                               # [LOCAL-AUTO] from `supabase start` output — SERVER ONLY
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres  # [LOCAL-AUTO]
SUPABASE_PROJECT_ID=                                     # [OPTIONAL] only needed for cloud deploy


# ─── Abstraction providers ──────────────────────────────────────────────────
# Each abstraction picks an adapter at boot based on these values.
# Fallbacks are chosen so the app runs with zero external dependencies.
LOGGER_PROVIDER=console                                  # [REQUIRED] console | sentry
ANALYTICS_PROVIDER=noop                                  # [REQUIRED] noop | posthog
FEATURE_FLAGS_PROVIDER=env                               # [REQUIRED] env | posthog | launchdarkly
PAYMENTS_PROVIDER=noop                                   # [REQUIRED] noop | stripe | paddle | lemonsqueezy
AUTOMATIONS_PROVIDER=noop                                # [REQUIRED] noop | n8n
CMS_PROVIDER=builtin                                     # [REQUIRED] builtin (only option shipped)
DOCS_ENGINE_PROVIDER=vault                               # [REQUIRED] vault (only option shipped)


# ─── Sentry (only when LOGGER_PROVIDER=sentry) ──────────────────────────────
SENTRY_DSN=                                              # [OPTIONAL] Server-side DSN
NEXT_PUBLIC_SENTRY_DSN=                                  # [OPTIONAL] Client-side DSN (often identical)
SENTRY_ORG=                                              # [OPTIONAL] For source-map upload during build
SENTRY_PROJECT=                                          # [OPTIONAL]
SENTRY_AUTH_TOKEN=                                       # [OPTIONAL] For source-map upload


# ─── Datadog (only when LOGGER_PROVIDER=datadog) ────────────────────────────
DATADOG_API_KEY=                                         # [OPTIONAL] API key for the Logs HTTP intake
DATADOG_SITE=datadoghq.com                               # [OPTIONAL] datadoghq.com | datadoghq.eu | us3.datadoghq.com
DATADOG_SERVICE=                                         # [OPTIONAL] service: tag applied to every record


# ─── PostHog (only when ANALYTICS_PROVIDER=posthog or FEATURE_FLAGS_PROVIDER=posthog) ──
POSTHOG_API_KEY=                                         # [OPTIONAL] Server-side (posthog-node)
NEXT_PUBLIC_POSTHOG_KEY=                                 # [OPTIONAL] Client-side (posthog-js)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com        # [OPTIONAL] Override for EU or self-hosted


# ─── Mixpanel (only when ANALYTICS_PROVIDER=mixpanel) ───────────────────────
MIXPANEL_TOKEN=                                          # [OPTIONAL] Project token
MIXPANEL_API_HOST=                                       # [OPTIONAL] https://api-eu.mixpanel.com for EU residency


# ─── Google Analytics 4 (only when ANALYTICS_PROVIDER=ga4) ──────────────────
GA4_MEASUREMENT_ID=                                      # [OPTIONAL] G-XXXXXXXXXX
GA4_API_SECRET=                                          # [OPTIONAL] From GA4 Admin → Data Streams → Measurement Protocol secrets


# ─── LaunchDarkly (only when FEATURE_FLAGS_PROVIDER=launchdarkly) ───────────
LAUNCHDARKLY_SDK_KEY=                                    # [OPTIONAL] Server-side SDK key (sdk-…)
LAUNCHDARKLY_ENDPOINT=                                   # [OPTIONAL] Override for EU / relay proxy


# ─── Stripe (only when PAYMENTS_PROVIDER=stripe) ────────────────────────────
# Use TEST mode keys. Production keys never belong in .env.local.
STRIPE_SECRET_KEY=                                       # [OPTIONAL] sk_test_…
STRIPE_WEBHOOK_SECRET=                                   # [OPTIONAL] whsec_…
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=                      # [OPTIONAL] pk_test_…


# ─── Paddle Billing (only when PAYMENTS_PROVIDER=paddle) ────────────────────
PADDLE_API_KEY=                                          # [OPTIONAL] pdl_live_… / pdl_sdbx_…
PADDLE_WEBHOOK_SECRET=                                   # [OPTIONAL] Dashboard → Notifications → Secret key
PADDLE_ENDPOINT=                                         # [OPTIONAL] https://sandbox-api.paddle.com for sandbox


# ─── Lemon Squeezy (only when PAYMENTS_PROVIDER=lemonsqueezy) ───────────────
LEMONSQUEEZY_API_KEY=                                    # [OPTIONAL] API key from Settings → API
LEMONSQUEEZY_WEBHOOK_SECRET=                             # [OPTIONAL] Signing secret from webhook config
LEMONSQUEEZY_STORE_ID=                                   # [OPTIONAL] Store id (numeric)


# ─── n8n webhook (only when AUTOMATIONS_PROVIDER=n8n) ───────────────────────
N8N_WEBHOOK_URL=                                         # [OPTIONAL]
N8N_WEBHOOK_SECRET=                                      # [OPTIONAL] Shared secret for HMAC verification


# ─── Feature flags (read by env-based flag provider) ────────────────────────
# Any flag resolved via the `env` adapter. Flip to `true` to enable.
FEATURE_STRIPE_CHECKOUT=false
FEATURE_NEWSLETTER=false
FEATURE_COMMENTS=false
FEATURE_AUDIT_LOG_VIEWER=true
FEATURE_ADMIN_UI=true


# ─── Rate limiting ──────────────────────────────────────────────────────────
# Defaults to in-memory LRU (fine for single-instance local dev).
# Switch to Upstash for multi-instance deploys.
RATE_LIMIT_PROVIDER=memory                               # [REQUIRED] memory | upstash
UPSTASH_REDIS_REST_URL=                                  # [OPTIONAL]
UPSTASH_REDIS_REST_TOKEN=                                # [OPTIONAL]


# ─── Optional cloud deploy (wired but inactive until filled) ────────────────
# Leave blank for local-only development. Used by `deploy-*` GitHub workflows.
VERCEL_TOKEN=                                            # [OPTIONAL]
VERCEL_ORG_ID=                                           # [OPTIONAL]
VERCEL_PROJECT_ID=                                       # [OPTIONAL]
