  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@startup-boilerplate/config": "workspace:*",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
