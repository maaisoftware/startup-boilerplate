{
  "name": "@startup-boilerplate/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed fetch client that only hits /api/*. The browser never talks to upstream services directly.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
