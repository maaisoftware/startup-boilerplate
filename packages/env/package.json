{
  "name": "@startup-boilerplate/env",
  "version": "0.1.0",
  "private": true,
  "description": "Zod-validated environment variables with typed server/client singletons. App refuses to start if required vars are missing.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./server-only": "./src/server-only.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "echo \"env is consumed as source — no build step\"",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf .turbo coverage node_modules/.cache"
  },
  "dependencies": {
    "server-only": "0.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@startup-boilerplate/config": "workspace:*",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
