{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React library",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "dom.iterable", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "types": ["node"]
  }
}
