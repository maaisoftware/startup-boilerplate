{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Test",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "test/**/*"]
}
