{
  "name": "@startup-boilerplate/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript, ESLint, Prettier, and Vitest configurations for every app and package in the monorepo.",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/next.json": "./tsconfig/next.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json",
    "./tsconfig/node-library.json": "./tsconfig/node-library.json",
    "./tsconfig/test.json": "./tsconfig/test.json",
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/next": "./eslint/next.mjs",
    "./eslint/react-library": "./eslint/react-library.mjs",
    "./eslint/node-library": "./eslint/node-library.mjs",
    "./prettier": "./prettier/index.cjs",
    "./vitest/base": "./vitest/base.mjs",
    "./vitest/node": "./vitest/node.mjs",
    "./vitest/react": "./vitest/react.mjs"
  },
  "files": [
    "tsconfig",
    "eslint",
    "prettier",
    "vitest"
  ],
  "scripts": {
    "lint": "echo \"config-only package — no lint target\"",
    "typecheck": "echo \"config-only package — no typecheck target\"",
    "test": "echo \"config-only package — no test target\"",
    "clean": "echo \"nothing to clean\""
  },
  "dependencies": {
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript-eslint": "8.59.0"
  },
  "peerDependencies": {
    "typescript": ">=6.0.0",
    "vitest": ">=4.0.0"
  }
}
