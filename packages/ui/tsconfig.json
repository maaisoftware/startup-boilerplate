{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@startup-boilerplate/config/tsconfig/react-library.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["src/**/*", "vitest.config.ts", "vitest.setup.ts"],
  "exclude": ["node_modules", "dist", ".turbo", "coverage"]
}
